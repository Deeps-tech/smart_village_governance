          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"aarav_citizen\",\n  \"password\": \"password123\",\n  \"email\": \"aarav@gmail.com\",\n  \"role\": \"CITIZEN\",\n  \"villageId\": \"VILL-001\"\n}",
              "options": {
                "raw": {
